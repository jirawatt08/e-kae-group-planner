{
  "emulators": {
    "firestore": {
      "port": 8080
    }
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": [
    {
      "database": "ai-studio-ee014588-0ed1-454e-a153-6e4fdf2a5269",
      "rules": "firestore.rules"
    }
  ]
}
